enum GitHubInstallationStatus {
  connected
  permission_gap
}

enum RepositoryBranchPolicy {
  default_branch_only
  workspace_selected
}

enum RepositorySyncTrigger {
  manual
  webhook
}

enum RepositorySyncRequestStatus {
  pending
  running
  completed
  failed
}

enum RepositoryIndexVersionStatus {
  building
  active
  failed
}

enum RepositoryHealthStatus {
  needs_setup
  ready
  syncing
  stale
  error
}

enum SearchFeedbackLabel {
  useful
  off_target
}

enum PrIntentStatus {
  validated
}

model GitHubInstallation {
  id                 String                   @id @default(cuid())
  workspaceId        String                   @unique
  workspace          Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  status               GitHubInstallationStatus @default(connected)
  githubInstallationId Int?
  installationOwner    String
  connectedAt        DateTime                 @default(now())
  missingPermissions String[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
}

model Repository {
  id                String                 @id @default(cuid())
  workspaceId       String
  workspace         Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner             String
  name              String
  fullName          String
  sourceRoot        String?
  defaultBranch     String                 @default("main")
  branchPolicy      RepositoryBranchPolicy @default(default_branch_only)
  selected          Boolean                @default(false)
  syncRequests      RepositorySyncRequest[]
  indexVersions     RepositoryIndexVersion[]
  searchQueries     CodeSearchQuery[]
  pullRequestIntents PullRequestIntent[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@unique([workspaceId, fullName])
  @@index([workspaceId, selected])
}

model RepositorySyncRequest {
  id           String                      @id @default(cuid())
  workspaceId  String
  repositoryId String
  workspace    Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repository   Repository                  @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  triggerSource RepositorySyncTrigger      @default(manual)
  status       RepositorySyncRequestStatus @default(pending)
  workflowId   String?
  requestedAt  DateTime                    @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?                     @db.Text
  indexVersion RepositoryIndexVersion?

  @@index([workspaceId, repositoryId, requestedAt])
  @@index([repositoryId, status])
}

model RepositoryIndexVersion {
  id           String                       @id @default(cuid())
  workspaceId  String
  repositoryId String
  syncRequestId String?                     @unique
  workspace    Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repository   Repository                   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  syncRequest  RepositorySyncRequest?       @relation(fields: [syncRequestId], references: [id], onDelete: SetNull)
  status       RepositoryIndexVersionStatus @default(building)
  commitSha    String?
  active       Boolean                      @default(false)
  startedAt    DateTime                     @default(now())
  completedAt  DateTime?
  activatedAt  DateTime?
  errorMessage String?                      @db.Text
  fileCount    Int                          @default(0)
  chunkCount   Int                          @default(0)
  chunks       RepositoryIndexChunk[]
  searchQueries CodeSearchQuery[]

  @@index([workspaceId, repositoryId, active])
  @@index([repositoryId, status])
}

model RepositoryIndexChunk {
  id             String                 @id @default(cuid())
  indexVersionId String
  indexVersion   RepositoryIndexVersion @relation(fields: [indexVersionId], references: [id], onDelete: Cascade)
  filePath       String
  language       String
  symbolName     String?
  lineStart      Int
  lineEnd        Int
  contentHash    String
  content        String                 @db.Text
  embedding      Unsupported("vector(1536)")?
  tsv            Unsupported("tsvector")?
  qualityScore   Float                  @default(0.5)
  embeddingModel String?
  createdAt      DateTime               @default(now())
  searchResults  CodeSearchResult[]

  @@index([indexVersionId, filePath])
  @@index([tsv], type: Gin)
  // embedding uses an HNSW index created via raw SQL in
  // 20260405200000_add_embedding_hybrid_search. Prisma's schema
  // cannot express `USING hnsw` — the CI drift check tolerates
  // this single unrepresentable index.
}

model CodeSearchQuery {
  id                     String                 @id @default(cuid())
  workspaceId            String
  repositoryId           String
  indexVersionId         String?
  workspace              Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repository             Repository             @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  indexVersion           RepositoryIndexVersion? @relation(fields: [indexVersionId], references: [id], onDelete: SetNull)
  query                  String                 @db.Text
  rankProfileVersion     String
  repositoryHealthStatus RepositoryHealthStatus
  fallbackRankingUsed    Boolean                @default(false)
  createdAt              DateTime               @default(now())
  results                CodeSearchResult[]
  feedback               SearchFeedback[]

  @@index([workspaceId, repositoryId, createdAt])
}

model CodeSearchResult {
  id             String          @id @default(cuid())
  queryId        String
  chunkId        String
  rank           Int
  query          CodeSearchQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  chunk          RepositoryIndexChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  keywordScore   Float
  semanticScore  Float
  pathScore      Float
  freshnessScore Float
  mergedScore    Float
  rerankerScore  Float?
  rerankerReason String?
  feedback       SearchFeedback[]

  @@index([queryId, rank])
  @@index([chunkId])
}

model SearchFeedback {
  id             String             @id @default(cuid())
  workspaceId     String
  queryId         String
  searchResultId  String
  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  query           CodeSearchQuery   @relation(fields: [queryId], references: [id], onDelete: Cascade)
  searchResult    CodeSearchResult  @relation(fields: [searchResultId], references: [id], onDelete: Cascade)
  label           SearchFeedbackLabel
  note            String?           @db.VarChar(280)
  createdAt       DateTime          @default(now())

  @@index([workspaceId, queryId, createdAt])
}

model PullRequestIntent {
  id                     String                 @id @default(cuid())
  workspaceId            String
  repositoryId           String
  workspace              Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repository             Repository             @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  title                  String
  targetBranch           String
  problemStatement       String                 @db.Text
  riskSummary            String                 @db.Text
  validationChecklist    String[]
  status                 PrIntentStatus         @default(validated)
  repositoryHealthStatus RepositoryHealthStatus
  humanApproval          Boolean
  createdAt              DateTime               @default(now())

  @@index([workspaceId, repositoryId, createdAt])
}
