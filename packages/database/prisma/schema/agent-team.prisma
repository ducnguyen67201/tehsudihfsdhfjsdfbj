model AgentTeam {
  id          String          @id @default(cuid())
  workspaceId String
  name        String
  description String?
  isDefault   Boolean         @default(false)
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  roles     AgentTeamRole[]
  edges     AgentTeamEdge[]
  runs      AgentTeamRun[]

  // TYPE GENERATION ONLY: DB uses partial unique index (WHERE deletedAt IS NULL).
  @@unique([workspaceId, name])
  @@index([workspaceId, isDefault])
}

model AgentTeamRole {
  id                   String             @id @default(cuid())
  teamId               String
  roleKey              String
  slug                 String
  label                String
  description          String?
  provider             String             @default("openai")
  model                String?
  toolIds              String[]
  systemPromptOverride String?            @db.Text
  maxSteps             Int                @default(8)
  sortOrder            Int                @default(0)
  metadata             Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  team        AgentTeam          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sourceEdges AgentTeamEdge[]    @relation("AgentTeamEdgeSource")
  targetEdges AgentTeamEdge[]    @relation("AgentTeamEdgeTarget")

  @@unique([teamId, roleKey])
  @@index([teamId, sortOrder])
}

model AgentTeamEdge {
  id           String   @id @default(cuid())
  teamId       String
  sourceRoleId String
  targetRoleId String
  condition    String?  @db.Text
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  team       AgentTeam     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sourceRole AgentTeamRole @relation("AgentTeamEdgeSource", fields: [sourceRoleId], references: [id], onDelete: Cascade)
  targetRole AgentTeamRole @relation("AgentTeamEdgeTarget", fields: [targetRoleId], references: [id], onDelete: Cascade)

  @@unique([teamId, sourceRoleId, targetRoleId])
  @@index([teamId, sortOrder])
}

model AgentTeamRun {
  id             String   @id @default(cuid())
  workspaceId    String
  teamId         String
  conversationId String?
  analysisId     String?
  // Resume chain. Points to the previous run's id when an operator-resume
  // started this run; null on the original. SetNull on parent delete keeps
  // the chain queryable even if the original row is removed.
  parentRunId    String?
  status         String   @default("queued")
  teamSnapshot   Json
  workflowId     String?
  startedAt      DateTime?
  completedAt    DateTime?
  errorMessage   String?  @db.Text
  summary        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace     Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  team          AgentTeam               @relation(fields: [teamId], references: [id], onDelete: Restrict)
  parentRun     AgentTeamRun?           @relation("AgentTeamRunResume", fields: [parentRunId], references: [id], onDelete: SetNull)
  childRuns     AgentTeamRun[]          @relation("AgentTeamRunResume")
  messages      AgentTeamMessage[]
  roleInboxes   AgentTeamRoleInbox[]
  facts         AgentTeamFact[]
  openQuestions AgentTeamOpenQuestion[]
  events        AgentTeamRunEvent[]

  @@index([workspaceId, status])
  @@index([conversationId])
  @@index([analysisId])
  @@index([parentRunId])
}

// Append-only event log for an agent-team run. Source of truth; derived read
// models (AgentTeamMessage / AgentTeamFact / AgentTeamOpenQuestion /
// AgentTeamRoleInbox) are populated by projectors inside the same transaction.
//
// DB TABLE IS PARTITIONED BY RANGE (ts). Prisma declares the logical shape here;
// the migration appends `PARTITION BY RANGE (ts)` + creates monthly partitions
// via $queryRawUnsafe. Do NOT run db:push on this model — it will recreate the
// table without partitions. Use db:migrate.
model AgentTeamRunEvent {
  id          String   @default(cuid())
  runId       String
  workspaceId String
  // Partition key. Included in composite PK because Postgres requires partition
  // columns to appear in any unique constraint on a partitioned table.
  ts          DateTime @default(now())

  actor       String
  kind        String
  target      String?
  messageKind String?

  payload     Json
  latencyMs   Int?
  tokensIn    Int?
  tokensOut   Int?
  truncated   Boolean  @default(false)

  run       AgentTeamRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Restrict)

  @@id([id, ts])
  @@index([runId, ts, id])
  @@index([workspaceId, ts])
  @@index([runId, actor, kind])
}

// Daily per-workspace rollup of agent-team activity. Populated by
// agent-team-metrics-rollup.workflow.ts (commit 7). One row per workspace per
// UTC day. Not wired to UI in this PR; exposed via SQL / downstream dashboards.
model WorkspaceAgentMetrics {
  id               String   @id @default(cuid())
  workspaceId      String
  day              DateTime @db.Date
  runsTotal        Int      @default(0)
  runsSucceeded    Int      @default(0)
  runsFailed       Int      @default(0)
  turnsTotal       Int      @default(0)
  toolCallsTotal   Int      @default(0)
  tokensTotal      Int      @default(0)
  toolLatencyP50Ms Int?
  toolLatencyP95Ms Int?
  turnWallP50Ms    Int?
  turnWallP95Ms    Int?
  computedAt       DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, day])
  @@index([day])
}

model AgentTeamMessage {
  id              String            @id @default(cuid())
  runId           String
  threadId        String
  fromRoleKey     String
  fromRoleSlug    String
  fromRoleLabel   String
  toRoleKey       String
  kind            String
  subject         String
  content         String            @db.Text
  parentMessageId String?
  refs            Json?
  toolName        String?
  metadata        Json?
  createdAt       DateTime          @default(now())

  run     AgentTeamRun       @relation(fields: [runId], references: [id], onDelete: Cascade)
  parent  AgentTeamMessage?  @relation("AgentTeamMessageParent", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies AgentTeamMessage[] @relation("AgentTeamMessageParent")

  @@index([runId, createdAt])
  @@index([runId, toRoleKey, createdAt])
  @@index([runId, threadId, createdAt])
  @@index([parentMessageId])
}

model AgentTeamRoleInbox {
  id                String   @id @default(cuid())
  runId             String
  roleKey           String
  state             String   @default("idle")
  lastReadMessageId String?
  wakeReason        String?
  unreadCount       Int      @default(0)
  lastWokenAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  run AgentTeamRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, roleKey])
  @@index([runId, state, updatedAt])
}

model AgentTeamFact {
  id               String   @id @default(cuid())
  runId            String
  statement        String   @db.Text
  confidence       Float
  sourceMessageIds Json
  acceptedByRoleKeys Json
  status           String   @default("proposed")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  run AgentTeamRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, status, createdAt])
}

model AgentTeamOpenQuestion {
  id              String   @id @default(cuid())
  runId           String
  askedByRoleKey  String
  ownerRoleKey    String
  question        String   @db.Text
  blockingRoleKeys Json
  status          String   @default("open")
  sourceMessageId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  run AgentTeamRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, ownerRoleKey, status, createdAt])
}
