// ── AI Analysis + Draft Generation ──────────────────────────────────

enum AnalysisTriggerMode {
  AUTO
  MANUAL
}

enum SupportAnalysisStatus {
  GATHERING_CONTEXT
  ANALYZING
  ANALYZED
  NEEDS_CONTEXT
  FAILED
}

enum SupportAnalysisSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SupportAnalysisCategory {
  BUG
  QUESTION
  FEATURE_REQUEST
  CONFIGURATION
  UNKNOWN
}

enum SupportAnalysisTriggerType {
  AUTO
  MANUAL
}

enum SupportDraftStatus {
  GENERATING
  AWAITING_APPROVAL
  APPROVED
  SENT
  DISMISSED
  FAILED
}

enum AnalysisEvidenceSourceType {
  CODE_CHUNK
}

model SupportAnalysis {
  id                String                      @id @default(cuid())
  workspaceId       String
  conversationId    String
  status            SupportAnalysisStatus       @default(GATHERING_CONTEXT)
  triggerType        SupportAnalysisTriggerType  @default(MANUAL)
  threadSnapshot    Json?
  customerEmail    String?
  retryCount        Int                          @default(0)
  problemStatement  String?                     @db.Text
  likelySubsystem   String?
  severity          SupportAnalysisSeverity?
  category          SupportAnalysisCategory?
  confidence        Float?
  missingInfo       Json?
  recommendedStance String?                     @db.Text
  reasoningTrace    String?                     @db.Text
  toolCallCount     Int?
  llmModel          String?
  llmLatencyMs      Int?
  errorMessage      String?                     @db.Text
  deletedAt         DateTime?
  workspace         Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  conversation      SupportConversation         @relation(fields: [conversationId], references: [id], onDelete: Restrict)
  evidence          AnalysisEvidence[]
  drafts            SupportDraft[]
  frames            SupportAnalysisFrame[]
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  @@index([conversationId, createdAt])
  @@index([workspaceId, status])
}

model AnalysisEvidence {
  id             String                      @id @default(cuid())
  analysisId     String
  sourceType     AnalysisEvidenceSourceType
  sourceId       String?
  filePath       String?
  snippet        String?                     @db.Text
  relevanceScore Float?
  citation       String?
  analysis       SupportAnalysis             @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  createdAt      DateTime                    @default(now())

  @@index([analysisId])
}

// Rendered keyframes from rrweb session replay shown to the support agent at
// analysis time. Persisted so the human reviewer (and any future re-analysis
// flow) can see exactly what the agent saw. base64Png stays on the row for
// v1; if blob volume grows past acceptable OLTP size, migrate to S3 keys.
model SupportAnalysisFrame {
  id           String           @id @default(cuid())
  analysisId   String
  timestamp    DateTime
  offsetMs     Int
  base64Png    String           @db.Text
  captionHint  String           @db.Text
  captionText  String?          @db.Text
  createdAt    DateTime         @default(now())
  analysis     SupportAnalysis  @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId, offsetMs])
}

model SupportDraft {
  id             String              @id @default(cuid())
  analysisId     String
  conversationId String
  workspaceId    String
  status         SupportDraftStatus  @default(GENERATING)
  draftBody      String              @db.Text
  editedBody     String?             @db.Text
  internalNotes  String?             @db.Text
  citations      Json?
  tone           String?
  llmModel       String?
  llmLatencyMs   Int?
  approvedBy     String?
  approvedAt     DateTime?
  sentAt         DateTime?
  prUrl          String?
  prNumber       Int?
  errorMessage   String?             @db.Text
  deletedAt      DateTime?
  analysis       SupportAnalysis     @relation(fields: [analysisId], references: [id], onDelete: Restrict)
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Restrict)
  workspace      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([analysisId])
  @@index([conversationId, createdAt])
  @@index([workspaceId, status])
}

model WorkspaceAiSettings {
  id              String    @id @default(cuid())
  workspaceId     String    @unique
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  defaultTone     String    @default("professional")
  responseStyle   String?   @db.Text
  signatureLine   String?
  maxDraftLength  Int       @default(500)
  includeCodeRefs Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
