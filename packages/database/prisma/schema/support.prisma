enum SupportProvider {
  SLACK
}

enum SupportIngressProcessingState {
  RECEIVED
  PROCESSED
  FAILED
}

enum SupportConversationStatus {
  UNREAD
  IN_PROGRESS
  STALE
  DONE
}

enum SupportConversationEventType {
  MESSAGE_RECEIVED
  STATUS_CHANGED
  ASSIGNEE_CHANGED
  MERGED
  SPLIT
  REASSIGNED_EVENT
  MERGE_UNDONE
  REASSIGN_UNDONE
  DELIVERY_ATTEMPTED
  DELIVERY_FAILED
  DELIVERY_SUCCEEDED
  DELIVERY_WARNING
  NOTE
  ANALYSIS_COMPLETED
  DRAFT_APPROVED
  DRAFT_DISMISSED
  DRAFT_SENT
  DRAFT_SEND_FAILED
  ANALYSIS_ESCALATED
}

/// Kind of grouping correction an operator performed. MVP ships MERGE + REASSIGN_EVENT.
/// Split is deferred.
enum SupportGroupingCorrectionKind {
  MERGE
  REASSIGN_EVENT
}

enum SupportAttachmentDirection {
  INBOUND
  OUTBOUND
}

enum SupportAttachmentUploadState {
  PENDING
  UPLOADED
  FAILED
}

enum SupportAttachmentLifecyclePolicy {
  ARCHIVE_NEVER
  ARCHIVE_AFTER_90D
  ARCHIVE_AFTER_1Y
}

enum SupportConversationEventSource {
  SYSTEM
  OPERATOR
  CUSTOMER
}

enum SupportDeliveryState {
  PENDING
  RETRYING
  SUCCEEDED
  FAILED
  DEAD_LETTERED
}

enum SupportDeadLetterSourceType {
  INGRESS
  GROUPING
  PROJECTION
  DELIVERY
  COMMAND
}

enum SupportTicketProvider {
  LINEAR
}

enum SupportTicketSyncState {
  PENDING
  SYNCED
  FAILED
}

model SupportInstallation {
  id                     String               @id @default(cuid())
  workspaceId            String
  provider               SupportProvider
  providerInstallationId String
  teamId                 String
  botUserId              String?
  oauthScopes            String[]             @default([])
  metadata               Json?
  deletedAt              DateTime?
  workspace              Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  ingressEvents          SupportIngressEvent[]
  conversations          SupportConversation[]
  threadAliases          SupportConversationThreadAlias[]
  customerProfiles       SupportCustomerProfile[]
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  // TYPE GENERATION ONLY: DB uses partial unique index (WHERE deletedAt IS NULL).
  @@unique([provider, providerInstallationId])
  @@index([workspaceId])
  // deletedAt: no standalone index (low selectivity). Partial composites cover hot paths.
}

model SupportIngressEvent {
  id                     String                       @id @default(cuid())
  workspaceId            String
  installationId         String
  provider               SupportProvider
  providerEventId        String
  canonicalIdempotencyKey String                      @unique
  rawPayloadJson         Json
  processingState        SupportIngressProcessingState @default(RECEIVED)
  receivedAt             DateTime                     @default(now())
  processedAt            DateTime?
  workspace              Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  installation           SupportInstallation          @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@index([workspaceId, receivedAt])
  @@index([installationId])
}

model SupportConversation {
  id                     String                    @id @default(cuid())
  workspaceId            String
  installationId         String
  canonicalConversationKey String
  teamId                 String
  channelId              String
  threadTs               String
  status                 SupportConversationStatus @default(UNREAD)
  assigneeUserId         String?
  lastCustomerMessageAt  DateTime?
  customerWaitingSince   DateTime?
  staleAt                DateTime?
  retryCount             Int                       @default(0)
  lastActivityAt         DateTime                  @default(now())
  /// Set when this conversation has been merged INTO another conversation.
  /// The target conversation now owns the merged timeline via UNION query
  /// on SupportConversationEvent.conversationId. Nullable — only populated
  /// for soft-deleted secondary rows post-merge. Breadcrumb only; Slack
  /// routing uses SupportConversationThreadAlias, not this column.
  mergedIntoConversationId String?
  deletedAt              DateTime?
  workspace              Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  installation           SupportInstallation       @relation(fields: [installationId], references: [id], onDelete: Restrict)
  assignee               User?                     @relation("SupportConversationAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  mergedInto             SupportConversation?      @relation("SupportConversationMergedInto", fields: [mergedIntoConversationId], references: [id], onDelete: SetNull)
  mergedChildren         SupportConversation[]     @relation("SupportConversationMergedInto")
  reassignedEvents       SupportConversationEvent[] @relation("SupportConversationEventReassignedFrom")
  groupingCorrections    SupportGroupingCorrection[] @relation("GroupingCorrectionSource")
  groupingCorrectionTargets SupportGroupingCorrection[] @relation("GroupingCorrectionTarget")
  events                 SupportConversationEvent[]
  deliveryAttempts       SupportDeliveryAttempt[]
  ticketLinks            SupportTicketLink[]
  groupingAnchors        SupportGroupingAnchor[]
  threadAliases          SupportConversationThreadAlias[]
  analyses               SupportAnalysis[]
  drafts                 SupportDraft[]
  attachments            SupportMessageAttachment[]
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  // TYPE GENERATION ONLY: DB uses partial unique index (WHERE deletedAt IS NULL).
  @@unique([workspaceId, canonicalConversationKey])
  @@index([workspaceId, teamId, channelId, threadTs])
  @@index([workspaceId, status, staleAt, customerWaitingSince, retryCount, lastActivityAt])
  @@index([installationId])
  @@index([assigneeUserId])
  @@index([mergedIntoConversationId])
  // deletedAt: no standalone index (low selectivity). Partial composites cover hot paths.
}

/// Maps a Slack thread_ts to a TrustLoop conversation.
///
/// When the operator delivers a reply into a Slack thread whose parent
/// is NOT the conversation's canonical thread_ts (e.g. because the
/// customer sent a later standalone message and the reply targets
/// that burst), an alias row is written here. Ingress checks this
/// table before canonical-key lookup so customer responses to that
/// thread route back to the original conversation instead of spawning
/// a phantom new one.
///
/// Unique on (installationId, channelId, threadTs) — each Slack thread
/// can only belong to one TrustLoop conversation.
model SupportConversationThreadAlias {
  id             String              @id @default(cuid())
  workspaceId    String
  conversationId String
  installationId String
  channelId      String
  threadTs       String
  workspace      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  installation   SupportInstallation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  createdAt      DateTime            @default(now())

  @@unique([installationId, channelId, threadTs])
  @@index([conversationId])
  @@index([workspaceId])
}

model SupportConversationEvent {
  id             String                         @id @default(cuid())
  workspaceId    String
  conversationId String
  eventType      SupportConversationEventType
  eventSource    SupportConversationEventSource
  summary        String?
  detailsJson    Json?
  /// Slack's message ts for MESSAGE_RECEIVED events. Promoted to a
  /// first-class column so thread-parent lookups can use a B-tree index
  /// instead of a JSONB path filter (which forces a sequential scan).
  /// Null for DELIVERY_ATTEMPTED / DELIVERY_SUCCEEDED and internal
  /// audit events — those don't become thread roots.
  messageTs      String?
  /// Resolved at ingress/reply time from Slack's thread_ts. When non-null,
  /// this event is a reply inside the parent event's thread. The UI groups
  /// children by this field without re-running the threadTs↔messageTs match.
  /// Null for thread roots, standalone messages, and orphans whose parent
  /// wasn't in the DB at ingest time (rare — Slack webhook ordering race).
  parentEventId  String?
  /// Set when an operator reassigned this event (typically a MESSAGE_RECEIVED)
  /// from its original conversation to this one. Points at the source
  /// conversation. Null for events that have never been moved. Breadcrumb
  /// for the conversation timeline UI.
  reassignedFromConversationId String?
  workspace      Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation   SupportConversation            @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  parent         SupportConversationEvent?      @relation("SupportConversationEventParent", fields: [parentEventId], references: [id], onDelete: SetNull)
  children       SupportConversationEvent[]     @relation("SupportConversationEventParent")
  reassignedFrom SupportConversation?           @relation("SupportConversationEventReassignedFrom", fields: [reassignedFromConversationId], references: [id], onDelete: SetNull)
  reassignedCorrections SupportGroupingCorrection[] @relation("GroupingCorrectionSourceEvent")
  attachments    SupportMessageAttachment[]
  reactions      SupportMessageReaction[]
  createdAt      DateTime                       @default(now())

  @@index([conversationId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([parentEventId])
  @@index([conversationId, messageTs])
}

model SupportDeliveryAttempt {
  id               String               @id @default(cuid())
  workspaceId      String
  conversationId   String
  commandId        String
  provider         SupportProvider
  providerMessageId String?
  attemptNumber    Int                  @default(1)
  state            SupportDeliveryState @default(PENDING)
  errorCode        String?
  errorMessage     String?
  nextRetryAt      DateTime?
  deletedAt        DateTime?
  workspace        Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  conversation     SupportConversation  @relation(fields: [conversationId], references: [id], onDelete: Restrict)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([workspaceId, state, nextRetryAt])
  @@index([conversationId, createdAt])
  // deletedAt: no standalone index (low selectivity). Partial composites cover hot paths.
}

model SupportDeadLetter {
  id             String                    @id @default(cuid())
  workspaceId    String
  sourceType     SupportDeadLetterSourceType
  sourceId       String
  failureClass   String
  failureReason  String
  payloadJson    Json
  firstFailedAt  DateTime                  @default(now())
  lastFailedAt   DateTime                  @default(now())
  retryCount     Int                       @default(1)
  resolvedAt     DateTime?
  workspace      Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, resolvedAt, lastFailedAt])
}

model SupportTicketLink {
  id               String                @id @default(cuid())
  workspaceId      String
  conversationId   String
  provider         SupportTicketProvider
  externalTicketId String
  externalStatus   String?
  syncState        SupportTicketSyncState @default(PENDING)
  lastSyncedAt     DateTime?
  deletedAt        DateTime?
  workspace        Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  conversation     SupportConversation   @relation(fields: [conversationId], references: [id], onDelete: Restrict)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  // TYPE GENERATION ONLY: DB uses partial unique index (WHERE deletedAt IS NULL).
  @@unique([workspaceId, provider, externalTicketId])
  @@index([conversationId])
  @@index([workspaceId, syncState, updatedAt])
  // deletedAt: no standalone index (low selectivity). Partial composites cover hot paths.
}

/// Maps standalone messages to conversations for time-window grouping.
/// An anchor tracks: which author, which channel, and which conversation
/// their standalone messages should be grouped into. Expires after a
/// configurable window (default 5 min, max 60 min).
model SupportGroupingAnchor {
  id                String              @id @default(cuid())
  workspaceId       String
  installationId    String
  channelId         String
  authorSlackUserId String
  conversationId    String
  anchorMessageTs   String
  windowStartAt     DateTime
  windowExpiresAt   DateTime
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  conversation      SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Restrict)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([workspaceId, channelId, authorSlackUserId, anchorMessageTs])
  @@index([workspaceId, channelId, authorSlackUserId, windowExpiresAt])
  @@index([conversationId])
}

model SupportMessageAttachment {
  id              String                          @id @default(cuid())
  workspaceId     String
  conversationId  String
  eventId         String?
  provider        SupportProvider
  providerFileId  String?
  storageKey      String?
  fileData        Bytes?
  mimeType        String
  sizeBytes       Int
  originalFilename String?
  title           String?
  direction       SupportAttachmentDirection
  uploadState     SupportAttachmentUploadState     @default(PENDING)
  errorCode       String?
  lifecyclePolicy SupportAttachmentLifecyclePolicy @default(ARCHIVE_NEVER)
  deletedAt       DateTime?
  workspace       Workspace                       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  conversation    SupportConversation             @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  event           SupportConversationEvent?        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @updatedAt

  @@index([conversationId, createdAt])
  @@index([workspaceId, uploadState])
  // TYPE GENERATION ONLY: DB uses partial unique index
  // (WHERE deletedAt IS NULL AND providerFileId IS NOT NULL).
  @@unique([provider, providerFileId, direction])
}

model SupportCustomerProfile {
  id               String              @id @default(cuid())
  workspaceId      String
  installationId   String
  provider         SupportProvider
  externalUserId   String
  displayName      String?
  realName         String?
  avatarUrl        String?
  isBot            Boolean             @default(false)
  isExternal       Boolean             @default(false)
  profileFetchedAt DateTime            @default(now())
  deletedAt        DateTime?
  workspace        Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  installation     SupportInstallation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  // TYPE GENERATION ONLY: DB uses partial unique index (WHERE deletedAt IS NULL).
  @@unique([installationId, externalUserId])
  @@index([workspaceId, provider])
  @@index([installationId])
}

model SupportMessageReaction {
  id           String                    @id @default(cuid())
  workspaceId  String
  eventId      String
  emojiName    String
  emojiUnicode String?
  actorUserId  String
  slackSynced  Boolean                   @default(false)
  workspace    Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  event        SupportConversationEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  actor        User                      @relation("SupportMessageReactionActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  createdAt    DateTime                  @default(now())

  @@unique([eventId, emojiName, actorUserId])
  @@index([eventId])
  @@index([workspaceId])
}

/// Log of operator-performed grouping corrections (merge and reassign).
/// Immutable audit trail + training corpus for future per-workspace
/// grouping-threshold tuning.
///
/// Scoped MVP shape: 8 columns, 2 indexes. No `inferredSignalJson`,
/// no `deletedAt` — corrections are never soft-deleted, they're an
/// audit trail. Extend when the learning loop consumer is actually built.
model SupportGroupingCorrection {
  id                   String                        @id @default(cuid())
  workspaceId          String
  actorUserId          String
  kind                 SupportGroupingCorrectionKind
  /// MERGE: the secondary conversation that was folded in.
  /// REASSIGN_EVENT: the conversation the event moved FROM.
  sourceConversationId String
  /// MERGE: the primary conversation (winner). REASSIGN_EVENT: the conversation
  /// the event moved TO. Nullable to keep the column reusable if future kinds
  /// omit a target (none currently).
  targetConversationId String?
  /// REASSIGN_EVENT: which event moved. Null for MERGE.
  sourceEventId        String?
  /// Client-supplied key scoped per workspace. On collision, the service
  /// returns the existing correction row instead of creating a duplicate.
  idempotencyKey       String
  /// Set when this correction has been reversed. Null while correction is
  /// still active. Undo rejects if set (already undone) or if the 24h
  /// window has elapsed.
  undoneAt             DateTime?
  createdAt            DateTime                      @default(now())
  workspace            Workspace                     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor                User                          @relation("SupportGroupingCorrectionActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  sourceConversation   SupportConversation           @relation("GroupingCorrectionSource", fields: [sourceConversationId], references: [id], onDelete: Cascade)
  targetConversation   SupportConversation?          @relation("GroupingCorrectionTarget", fields: [targetConversationId], references: [id], onDelete: SetNull)
  sourceEvent          SupportConversationEvent?     @relation("GroupingCorrectionSourceEvent", fields: [sourceEventId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, createdAt])
  @@index([sourceConversationId])
  @@index([targetConversationId])
}
