// ── Session Replay ──────────────────────────────────────────────────

enum SessionEventType {
  CLICK
  ROUTE
  NETWORK_ERROR
  CONSOLE_ERROR
  EXCEPTION
}

model SessionRecord {
  id            String               @id @default(cuid())
  workspaceId   String
  sessionId     String
  userId        String?
  userEmail     String?
  release       String?
  userAgent     String?
  startedAt     DateTime
  lastEventAt   DateTime
  eventCount    Int                  @default(0)
  hasReplayData Boolean              @default(false)
  metadata      Json?
  deletedAt     DateTime?
  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  events        SessionEvent[]
  replayChunks  SessionReplayChunk[]
  conversationMatches SupportConversationSessionMatch[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([workspaceId, sessionId])
  @@index([workspaceId, userEmail, lastEventAt])
  @@index([workspaceId, userId, lastEventAt])
}

model SessionEvent {
  id              String           @id @default(cuid())
  workspaceId     String
  sessionRecordId String
  eventType       SessionEventType
  timestamp       DateTime
  url             String?
  payload         Json
  sessionRecord   SessionRecord    @relation(fields: [sessionRecordId], references: [id], onDelete: Cascade)
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  createdAt       DateTime         @default(now())

  @@index([sessionRecordId, timestamp])
}

model SessionReplayChunk {
  id              String        @id @default(cuid())
  workspaceId     String
  sessionRecordId String
  sequenceNumber  Int
  compressedData  Bytes
  eventCount      Int
  startTimestamp  DateTime
  endTimestamp    DateTime
  sessionRecord   SessionRecord @relation(fields: [sessionRecordId], references: [id], onDelete: Cascade)
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  createdAt       DateTime      @default(now())

  @@unique([sessionRecordId, sequenceNumber])
}

model SupportConversationSessionMatch {
  id                     String              @id @default(cuid())
  workspaceId            String
  conversationId         String
  sessionRecordId        String
  matchSource            String
  matchConfidence        String
  matchedIdentifierType  String
  matchedIdentifierValue String
  score                  Int
  evidenceJson           Json?
  isPrimary              Boolean             @default(false)
  workspace              Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation           SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sessionRecord          SessionRecord       @relation(fields: [sessionRecordId], references: [id], onDelete: Cascade)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  @@unique([conversationId, sessionRecordId], map: "SupportConvSessionMatch_conversation_session_key")
  @@index([workspaceId, conversationId, isPrimary], map: "SupportConvSessionMatch_workspace_conversation_primary_idx")
  @@index([sessionRecordId, isPrimary], map: "SupportConvSessionMatch_session_primary_idx")
}
