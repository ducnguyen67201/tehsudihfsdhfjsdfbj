{
  "name": "@shared/database",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsgo --noEmit",
    "lint": "biome check .",
    "test": "vitest run --passWithNoTests",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:new-workspace": "tsx ./scripts/new-workspace.ts",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@shared/env": "*",
    "pg": "^8.15.6"
  },
  "devDependencies": {
    "dotenv": "^17.2.2",
    "prisma": "^7.0.0"
  }
}
