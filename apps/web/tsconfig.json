{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"],
      "@shared/types": ["../../packages/types/src/index.ts"],
      "@shared/types/*": ["../../packages/types/src/*"],
      "@shared/rest": ["../../packages/rest/src/index.ts"],
      "@shared/rest/*": ["../../packages/rest/src/*"],
      "@shared/database": ["../../packages/database/src/index.ts"],
      "@shared/database/*": ["../../packages/database/src/*"],
      "@shared/env": ["../../packages/env/src/index.ts"],
      "@shared/env/*": ["../../packages/env/src/*"],
      "@shared/brand": ["../../packages/brand/src/index.ts"],
      "@shared/brand/*": ["../../packages/brand/src/*"],
      "@apps/queue": ["../../apps/queue/src/index.ts"],
      "@apps/queue/*": ["../../apps/queue/src/*"]
    }
  },
  "include": ["next-env.d.ts", "src", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
