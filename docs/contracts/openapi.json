      "SearchCodeRequest": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "workspaceId": {
            "type": "string",
            "minLength": 1
          },
          "repositoryId": {
            "type": "string",
            "minLength": 1
          },
          "query": {
            "type": "string",
            "minLength": 3
          },
          "limit": {
