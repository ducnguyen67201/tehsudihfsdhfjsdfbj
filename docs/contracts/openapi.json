                  "required": [
                    "status",
                    "staleAfterMinutes",
                    "lastSyncRequestedAt",
                    "lastCompletedAt",
                    "activeCommitSha",
                    "activeVersionId",
                    "lastErrorMessage",
                    "syncStageLabel"
