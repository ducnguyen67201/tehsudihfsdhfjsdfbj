                        },
                        {
                          "type": "null"
                        }
                      ]
                    },
                    "activeCommitSha": {
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "null"
                        }
                      ]
                    },
                    "activeVersionId": {
                      "anyOf": [
                        {
                          "type": "string"
