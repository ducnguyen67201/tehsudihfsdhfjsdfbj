{
  "name": "trustloop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:web": "npm --workspace @trustloop/web run dev",
    "dev:web:debug": "TRUSTLOOP_DEBUG_TRPC=1 NEXT_PUBLIC_TRUSTLOOP_DEBUG_TRPC=1 npm --workspace @trustloop/web run dev",
    "dev:queue": "npm --workspace @apps/queue run dev",
    "dev:agents": "npm --workspace @trustloop/agents run dev",
    "dev:marketing": "npm --workspace @trustloop/marketing run dev",
    "dev:demo": "npm --workspace @trustloop/sdk run dev & npm --workspace @trustloop/demo-app run dev",
    "doppler:dev": "doppler run -- turbo run dev --parallel",
    "doppler:dev:web": "doppler run -- npm --workspace @trustloop/web run dev",
    "doppler:dev:queue": "doppler run -- npm --workspace @apps/queue run dev",
    "doppler:dev:agents": "doppler run -- npm --workspace @trustloop/agents run dev",
    "check": "npm run type-check && npm run lint && npm run test && npm run build && npm run openapi:check && npm run db:generate",
    "check:clean": "npm run check && npm run clean:artifacts",
    "type-check": "turbo run type-check",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "npm --workspace @shared/database run db:generate && npm --workspace @shared/types run prisma:sync",
    "db:migrate": "npm --workspace @shared/database run db:migrate",
    "db:migrate:deploy": "npm --workspace @shared/database run db:migrate:deploy",
    "db:new-workspace": "npm --workspace @shared/database run db:new-workspace --",
    "openapi:generate": "npm --workspace @shared/rest run openapi:generate",
    "openapi:check": "npm --workspace @shared/rest run openapi:check",
    "clean:artifacts": "rm -rf .turbo apps/*/.turbo packages/*/.turbo apps/*/dist packages/*/dist apps/web/.next coverage && find . -name '*.tsbuildinfo' -type f -delete",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": "biome check --fix --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.14.1",
    "@typescript/native-preview": "^7.0.0-dev.20260329.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.20.6",
    "turbo": "^2.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.1.1"
  }
}
