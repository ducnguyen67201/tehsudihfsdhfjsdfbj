{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "deploy/agents.Dockerfile",
    "watchPatterns": [
      "apps/agents/**",
      "packages/types/**",
      "packages/database/**",
      "packages/env/**",
      "packages/prompting/**",
      "deploy/agents.Dockerfile",
      "deploy/railway.agents.json",
      ".dockerignore",
      "package.json",
      "package-lock.json"
    ]
  },
  "deploy": {
    "startCommand": "npx tsx apps/agents/src/server.ts",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
