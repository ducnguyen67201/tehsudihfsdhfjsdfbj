{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "deploy/marketing.Dockerfile",
    "watchPatterns": [
      "apps/marketing/**",
      "packages/brand/**",
      "deploy/marketing.Dockerfile",
      "deploy/railway.marketing.json",
      ".dockerignore",
      "package.json",
      "package-lock.json"
    ]
  },
  "deploy": {
    "startCommand": "node apps/marketing/server.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
