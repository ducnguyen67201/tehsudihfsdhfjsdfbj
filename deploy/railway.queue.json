{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "deploy/queue.Dockerfile",
    "watchPatterns": [
      "apps/queue/**",
      "packages/rest/**",
      "packages/types/**",
      "packages/database/**",
      "packages/env/**",
      "deploy/queue.Dockerfile",
      "deploy/railway.queue.json",
      ".dockerignore",
      "package.json",
      "package-lock.json"
    ]
  },
  "deploy": {
    "startCommand": "npx tsx apps/queue/src/main.ts",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
