# ------------------------------------------------------------------
# TrustLoop environment variables
# For local dev without Doppler, copy to .env and fill in values.
# With Doppler: run `npm run doppler:dev` (secrets injected at runtime).
# ------------------------------------------------------------------

# Set to "1" to skip env validation (useful for Docker/CI builds)
# SKIP_ENV_VALIDATION=0

NODE_ENV=development
APP_BASE_URL=http://localhost:3000
SESSION_COOKIE_NAME=trustloop_session
SESSION_TTL_HOURS=168
SESSION_SECRET=dev-only-trustloop-session-secret
API_KEY_PEPPER=dev-only-trustloop-api-key-pepper
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trustloop?schema=public
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=support-general
CODEX_TASK_QUEUE=codex-intensive
SUPPORT_INGEST_ENABLED=0
SLACK_SIGNING_SECRET=dev-only-trustloop-slack-signing-secret
SLACK_REPLAY_WINDOW_SECONDS=300
SLACK_BOT_TOKEN=xoxb-dev-placeholder
TRUSTLOOP_DEBUG_TRPC=0
NEXT_PUBLIC_TRUSTLOOP_DEBUG_TRPC=0
